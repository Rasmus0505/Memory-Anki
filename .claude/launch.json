{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "--app-dir", "src", "memory_anki.app.main:app", "--host", "127.0.0.1", "--port", "8000", "--reload"],
      "port": 8000,
      "cwd": "apps/api"
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "127.0.0.1", "--port", "5173"],
      "port": 5173,
      "cwd": "apps/web",
      "autoPort": true
    }
  ]
}
