# Copy this file to .env for local development. Do not commit real secrets.

# Runtime storage. Leave empty to use the default:
# Windows: %LOCALAPPDATA%\MemoryAnki
# Other systems: ~/AppData/Local/MemoryAnki
MEMORY_ANKI_HOME=

# Optional override used by production/supervisor flows.
MEMORY_ANKI_WEB_DIST=
MEMORY_ANKI_CEFR_SOURCE=
MEMORY_ANKI_RUN_MODE=

# AI provider keys. Fill only the providers you use locally.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_TTS_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-filetrans
DASHSCOPE_VISION_MODEL=qwen3-vl-flash
DASHSCOPE_OCR_MODEL=qwen3.5-ocr
DASHSCOPE_TEXT_MODEL=qwen3.6-flash
ENGLISH_TRANSLATION_MODEL=qwen-mt-flash

ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
