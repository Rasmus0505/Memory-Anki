# Copy this file to .env for local development. Do not commit real secrets.

# Runtime storage. Leave empty to use the default:
# Windows: %LOCALAPPDATA%\MemoryAnki
# Other systems: ~/AppData/Local/MemoryAnki
MEMORY_ANKI_HOME=

# Optional override used by production/supervisor flows.
MEMORY_ANKI_WEB_DIST=
MEMORY_ANKI_CEFR_SOURCE=
MEMORY_ANKI_RUN_MODE=

# Cloud deployment.
# Use "cloud" on Render/Fly/Railway. Leave "local" for desktop/Tailscale.
MEMORY_ANKI_DEPLOY_TARGET=local

# Leave empty for local SQLite. Set to a Supabase/Postgres SQLAlchemy URL in cloud API hosts.
# Example: postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-us-east-2.pooler.supabase.com:6543/postgres
MEMORY_ANKI_DATABASE_URL=

# Comma-separated CORS allowlist for the API. Keep "*" for local development only.
# Example: https://memory-anki.vercel.app,https://memory-anki-git-main-your-team.vercel.app
MEMORY_ANKI_CORS_ORIGINS=*

# Vite frontend API origin. Leave empty when the frontend is served by the same FastAPI origin.
# Example: https://memory-anki-api.onrender.com
VITE_API_ORIGIN=

# AI provider keys. Fill only the providers you use locally.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_TTS_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-filetrans
DASHSCOPE_VISION_MODEL=qwen3-vl-flash
DASHSCOPE_OCR_MODEL=qwen3.5-ocr
DASHSCOPE_TEXT_MODEL=qwen3.6-flash
ENGLISH_TRANSLATION_MODEL=qwen-mt-flash

ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
